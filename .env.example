# Copie para .env e ajuste:  cp .env.example .env

# === Repositorio a explorar ===
# Montado em /workspace (somente-leitura). Use caminho absoluto.
# Windows (Docker Desktop):   REPO_PATH=C:\Users\david\dev\gather_app
# Dentro do WSL2:             REPO_PATH=/home/david/dev/gather_app
REPO_PATH=./repo

# === LM Studio (no host) ===
# Em LM Studio: aba Developer > Server. LIGUE "Serve on Local Network"
# (faz bind em 0.0.0.0). Sem isso o container NAO alcanca via host.docker.internal.
BASE_URL=http://host.docker.internal:1234/v1
API_KEY=lm-studio

# Id EXATO do modelo como aparece na UI/endpoint do LM Studio.
# PRECISA suportar tool/function calling (FastContext depende de Read/Glob/Grep).
# Obs: se o nome contiver "qwen", o FastContext envia chat_template_kwargs
# (enable_thinking=False) e top_k=20 automaticamente.
MODEL=qwen/qwen3.5-4b

# === Build ===
# Pinne um commit para auditar antes de buildar (recomendado).
# FASTCONTEXT_REF=main
